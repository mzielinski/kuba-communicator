# KUBA App - Apache Rewrite Rules
# Routes all requests through the PHP router (index.php)
# which serves static files from /public/ and API from /src/

Options -Indexes

FileETag None

# Security Headers
<IfModule mod_headers.c>
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" env=HTTPS
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Cache Control
# JS, CSS, HTML: always revalidate — changes (e.g. translations) are picked up immediately without needing a hard refresh.
<IfModule mod_headers.c>
    <FilesMatch "\.(js|css|html)$">
        Header set Cache-Control "no-store, no-cache, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
        Header unset ETag
    </FilesMatch>
    # Images & fonts can be cached longer
    <FilesMatch "\.(png|jpg|jpeg|gif|svg|woff|woff2|ttf|eot|ico)$">
        Header set Cache-Control "max-age=86400, public"
    </FilesMatch>
</IfModule>

RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Allow direct access to email confirmation endpoint
RewriteRule ^src/auth/confirm-email\.php - [L]

# Block direct access to sensitive directories
RewriteRule ^(src|data)(/|$) - [F,L]

# Don't rewrite actual existing files (e.g. index.php)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Don't rewrite actual existing directories
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route everything else through the PHP router
RewriteRule ^ index.php [L,QSA]
