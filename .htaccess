# KUBA App - Apache Rewrite Rules
# Routes all requests through the PHP router (index.php)
# which serves static files from /public/ and API from /src/

Options -Indexes

# Security Headers
<IfModule mod_headers.c>
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" env=HTTPS
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Allow direct access to email confirmation endpoint
RewriteRule ^src/auth/confirm-email\.php - [L]

# Block direct access to sensitive directories
RewriteRule ^(src|data)(/|$) - [F,L]

# Don't rewrite actual existing files (e.g. index.php)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Don't rewrite actual existing directories
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route everything else through the PHP router
RewriteRule ^ index.php [L,QSA]
